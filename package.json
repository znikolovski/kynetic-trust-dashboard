{
  "name": "securbank-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "SecurBank authenticated dashboard — Next.js app that replaces securbank-ue.vercel.app, sharing the Kinetic Trust design system with the EDS marketing site and reading personalized data from AEM Cloud Service via GraphQL persisted queries.",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:widgets && next build",
    "build:widgets": "node widgets/build.mjs",
    "start": "next start",
    "lint": "next lint",
    "smoke-test:widget": "node scripts/smoke-test-widget.mjs"
  },
  "dependencies": {
    "next": "15.1.11",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.9.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "eslint": "8.57.1",
    "eslint-config-next": "15.1.0",
    "esbuild": "0.24.0",
    "playwright": "1.48.2"
  }
}
